{
  "name": "zeroai",
  "version": "1.1.0",
  "description": "Zero-cost AI access from your terminal — stacks 10+ free providers, smart routing, auto-fallback, MCP server",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "zeroai": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "chat": "node --loader ts-node/esm src/cli.ts",
    "serve": "node --loader ts-node/esm src/mcp-server.ts",
    "doctor": "node --loader ts-node/esm src/cli.ts doctor",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "ai",
    "cli",
    "mcp",
    "free",
    "zero-cost",
    "gemini",
    "groq",
    "mistral",
    "deepseek",
    "openrouter",
    "cerebras",
    "ollama",
    "llm",
    "router",
    "fallback",
    "circuit-breaker"
  ],
  "author": "rahlplx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rahlplx/zeroai.git"
  },
  "homepage": "https://github.com/rahlplx/zeroai#readme"
}
